<UserControl
    x:Class="OmegaAssetStudio.WinUI.Modules.MaterialEditor.MaterialOverrideTool.OverrideParameterControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Border Padding="12"
            CornerRadius="10"
            Background="{ThemeResource OmegaAssetStudio.PanelSecondaryBrush}"
            BorderBrush="{ThemeResource OmegaAssetStudio.PanelBorderBrush}"
            BorderThickness="1">
        <StackPanel Spacing="8">
            <TextBlock Text="Override Parameters" FontWeight="SemiBold" />
            <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
                <TextBox Header="Tint" Text="{Binding TintColorText, Mode=TwoWay}" />
                <TextBox Grid.Column="1" Header="Roughness Scale" Text="{Binding RoughnessScaleText, Mode=TwoWay}" />
            </Grid>
            <TextBox Header="Emissive Scale" Text="{Binding EmissiveScaleText, Mode=TwoWay}" />
            <Grid ColumnDefinitions="*,*,*" ColumnSpacing="8">
                <Button Grid.Column="0" Click="AddParameter_Click">
                    <TextBlock Text="Add Parameter" TextWrapping="WrapWholeWords" TextAlignment="Center" />
                </Button>
                <Button Grid.Column="1" Click="ApplyOverrides_Click">
                    <TextBlock Text="Apply Overrides" TextWrapping="WrapWholeWords" TextAlignment="Center" />
                </Button>
                <Button Grid.Column="2" Click="ResetProfile_Click">
                    <TextBlock Text="Reset Profile" TextWrapping="WrapWholeWords" TextAlignment="Center" />
                </Button>
            </Grid>
            <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
                <Button Grid.Column="0" Click="ExportProfile_Click">
                    <TextBlock Text="Export Profile" TextWrapping="WrapWholeWords" TextAlignment="Center" />
                </Button>
                <Button Grid.Column="1" Click="ImportProfile_Click">
                    <TextBlock Text="Import Profile" TextWrapping="WrapWholeWords" TextAlignment="Center" />
                </Button>
            </Grid>
            <ItemsControl ItemsSource="{Binding OverrideParameters}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Padding="8"
                                CornerRadius="6"
                                Background="{ThemeResource OmegaAssetStudio.PanelBackgroundBrush}">
                            <Grid ColumnDefinitions="2*,*,Auto" ColumnSpacing="8">
                                <StackPanel>
                                    <TextBlock FontWeight="SemiBold" Text="{Binding Name}" TextWrapping="WrapWholeWords" />
                                    <TextBlock Opacity="0.75" Text="{Binding Category}" TextWrapping="WrapWholeWords" />
                                </StackPanel>
                                <TextBox Grid.Column="1" Text="{Binding ValueText, Mode=TwoWay}" />
                                <Button Grid.Column="2"
                                        Content="Remove"
                                        Click="RemoveParameter_Click"
                                        Tag="{Binding}" />
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
            <TextBlock Text="{Binding StatusText}" Opacity="0.75" TextWrapping="WrapWholeWords" />
        </StackPanel>
    </Border>
</UserControl>
