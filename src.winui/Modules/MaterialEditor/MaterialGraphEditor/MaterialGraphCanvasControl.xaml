<UserControl
    x:Class="OmegaAssetStudio.WinUI.Modules.MaterialEditor.MaterialGraphEditor.MaterialGraphCanvasControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Border Padding="12"
            CornerRadius="10"
            Background="{ThemeResource OmegaAssetStudio.PanelSecondaryBrush}"
            BorderBrush="{ThemeResource OmegaAssetStudio.PanelBorderBrush}"
            BorderThickness="1">
        <Grid RowDefinitions="Auto,*">
            <TextBlock Text="Graph Canvas" FontWeight="SemiBold" />
            <ScrollViewer Grid.Row="1"
                          HorizontalScrollBarVisibility="Auto"
                          VerticalScrollBarVisibility="Auto">
                <Canvas x:Name="GraphCanvas"
                        Width="2200"
                        Height="1200" />
            </ScrollViewer>
        </Grid>
    </Border>
</UserControl>
