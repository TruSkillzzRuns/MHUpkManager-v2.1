<Page
    x:Class="OmegaAssetStudio.WinUI.Modules.MaterialEditor.MaterialEditorView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:core="using:OmegaAssetStudio.WinUI.Modules.MaterialEditor.Core"
    xmlns:rendering="using:OmegaAssetStudio.WinUI.Modules.MaterialEditor.Rendering"
    mc:Ignorable="d">

    <Grid Padding="16"
          RowDefinitions="Auto,*"
          ColumnSpacing="14"
          RowSpacing="14"
          Background="{ThemeResource OmegaAssetStudio.PageBackgroundBrush}">
        <Border Grid.Row="0"
                Padding="12"
                CornerRadius="10"
                Background="{ThemeResource OmegaAssetStudio.PanelBackgroundBrush}"
                BorderBrush="{ThemeResource OmegaAssetStudio.PanelBorderBrush}"
                BorderThickness="1">
            <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12" RowDefinitions="Auto,Auto">
                <Button Grid.RowSpan="2" Content="Load UPK..." Click="LoadUpk_Click" />
                <StackPanel Grid.Column="1" Spacing="4">
                    <TextBlock Style="{ThemeResource TitleTextBlockStyle}" Text="Loaded UPK(s)" />
                    <TextBlock Text="{Binding LoadedUpkText}" TextWrapping="WrapWholeWords" />
                </StackPanel>
                <StackPanel Grid.Column="2" HorizontalAlignment="Right" VerticalAlignment="Center" Spacing="4">
                    <Button Content="Save Material" Click="SaveMaterial_Click" />
                    <Button Content="Undo Last Change"
                            Click="UndoLastChange_Click"
                            IsEnabled="{Binding CanUndo}" />
                    <TextBlock HorizontalAlignment="Right" Text="{Binding StatusText}" TextWrapping="WrapWholeWords" />
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1" RowSpacing="14" ColumnSpacing="14">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="220" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.3*" />
                <ColumnDefinition Width="1.1*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Grid.Row="0"
                    Padding="12"
                    CornerRadius="10"
                    Background="{ThemeResource OmegaAssetStudio.PanelBackgroundBrush}"
                    BorderBrush="{ThemeResource OmegaAssetStudio.PanelBorderBrush}"
                    BorderThickness="1">
                <Grid RowDefinitions="Auto,Auto,Auto,*,Auto" RowSpacing="8">
                    <Grid ColumnDefinitions="*" RowDefinitions="Auto,Auto" RowSpacing="8">
                        <TextBlock Style="{ThemeResource TitleTextBlockStyle}"
                                   Text="Material Preview"
                                   TextWrapping="WrapWholeWords" />
                        <StackPanel Grid.Row="1"
                                    Orientation="Horizontal"
                                    VerticalAlignment="Center"
                                    Spacing="8">
                            <Button Content="Reset All" Click="ResetAll_Click" />
                            <TextBlock VerticalAlignment="Center" Text="Skeletal Mesh" />
                            <ComboBox MinWidth="260"
                                      MaxWidth="520"
                                      ItemsSource="{Binding PreviewSkeletalMeshExports}"
                                      SelectedItem="{Binding SelectedPreviewSkeletalMeshExportPath, Mode=TwoWay}"
                                      PlaceholderText="Choose a preview mesh" />
                            <TextBlock VerticalAlignment="Center" Text="Preview LOD" />
                            <ComboBox Width="120"
                                      ItemsSource="{Binding PreviewLodOptions}"
                                      SelectedIndex="{Binding SelectedPreviewLodIndex, Mode=TwoWay}" />
                        </StackPanel>
                    </Grid>
                    <TextBlock Grid.Row="1"
                               Text="{Binding PreviewMeshSelectionText}"
                               Opacity="0.75"
                               TextWrapping="WrapWholeWords" />
                    <TextBlock Grid.Row="2" Text="{Binding SelectedMaterialSummary}" TextWrapping="WrapWholeWords" />
                    <rendering:MaterialPreviewHost x:Name="PreviewHost"
                                                   Grid.Row="3"
                                                   CurrentMaterial="{Binding SelectedMaterial}"
                                                   PreviewConfig="{Binding PreviewConfig}"
                                                   PreviewMeshUpkPath="{Binding PreviewMeshUpkPath}"
                                                   PreviewMeshExportPath="{Binding PreviewMeshExportPath}"
                                                   PreviewLodIndex="{Binding SelectedPreviewLodIndex}"
                                                   PreviewTextureSlotPath="{Binding PreviewTextureSlotPath}"
                                                   PreviewTextureMipIndex="{Binding PreviewTextureMipIndex}"
                                                   PreviewRefreshToken="{Binding PreviewRefreshToken}"
                                                   MinHeight="720"
                                                   HorizontalAlignment="Stretch"
                                                   VerticalAlignment="Stretch" />
                    <Border Grid.Row="4"
                            Padding="8"
                            CornerRadius="6"
                            Background="{ThemeResource OmegaAssetStudio.PanelSecondaryBrush}">
                        <TextBlock Text="{Binding DiagnosticsText, ElementName=PreviewHost}"
                                   TextWrapping="WrapWholeWords"
                                   Opacity="0.9" />
                    </Border>
                </Grid>
            </Border>

            <Border Grid.Column="0"
                    Grid.Row="1"
                    Padding="12"
                    CornerRadius="10"
                    Background="{ThemeResource OmegaAssetStudio.PanelBackgroundBrush}"
                    BorderBrush="{ThemeResource OmegaAssetStudio.PanelBorderBrush}"
                    BorderThickness="1">
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <StackPanel Spacing="8">
                        <TextBlock Style="{ThemeResource TitleTextBlockStyle}"
                                   Text="Material Browser"
                                   TextWrapping="WrapWholeWords" />
                        <TextBlock Text="Select a material to inspect or edit." TextWrapping="Wrap" />
                        <ListView ItemsSource="{Binding Materials}"
                                  SelectedItem="{Binding SelectedMaterial, Mode=TwoWay}"
                                  HorizontalContentAlignment="Stretch"
                                  ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                            <ListView.ItemContainerStyle>
                                <Style TargetType="ListViewItem">
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                    <Setter Property="Padding" Value="0" />
                                </Style>
                            </ListView.ItemContainerStyle>
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <Border Padding="8"
                                            CornerRadius="6"
                                            Background="{ThemeResource OmegaAssetStudio.PanelSecondaryBrush}">
                                        <StackPanel Spacing="2">
                                            <TextBlock FontWeight="SemiBold"
                                                       Text="{Binding Name}"
                                                       TextWrapping="Wrap"
                                                       ToolTipService.ToolTip="{Binding Name}" />
                                            <TextBlock Opacity="0.8"
                                                       Text="{Binding Type}"
                                                       TextWrapping="Wrap"
                                                       ToolTipService.ToolTip="{Binding Type}" />
                                            <TextBlock Opacity="0.8"
                                                       Text="{Binding Path}"
                                                       TextWrapping="Wrap"
                                                       ToolTipService.ToolTip="{Binding Path}" />
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <Border Grid.Column="1"
                    Grid.Row="0"
                    Grid.RowSpan="2"
                    Padding="12"
                    CornerRadius="10"
                    Background="{ThemeResource OmegaAssetStudio.PanelBackgroundBrush}"
                    BorderBrush="{ThemeResource OmegaAssetStudio.PanelBorderBrush}"
                    BorderThickness="1">
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <StackPanel Spacing="10">
                        <StackPanel Spacing="6">
                            <TextBlock Style="{ThemeResource TitleTextBlockStyle}"
                                       Text="Material Tools"
                                       TextWrapping="WrapWholeWords" />
                            <ComboBox x:Name="MaterialToolComboBox"
                                      SelectionChanged="MaterialToolComboBox_SelectionChanged" />
                            <ContentControl x:Name="MaterialToolHost"
                                            MinHeight="280" />
                        </StackPanel>

                        <TextBlock Style="{ThemeResource TitleTextBlockStyle}"
                                   Text="Material Inspector"
                                   TextWrapping="WrapWholeWords" />

                        <StackPanel Spacing="6">
                            <TextBlock FontWeight="SemiBold"
                                       Text="Texture Slots"
                                       TextWrapping="WrapWholeWords" />
                            <TextBlock Text="{Binding SelectedTextureMetadataText}" TextWrapping="Wrap" />
                            <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8">
                                <TextBlock VerticalAlignment="Center"
                                           Text="Preview MIP"
                                           TextWrapping="WrapWholeWords" />
                                <ComboBox Grid.Column="1"
                                          MinWidth="260"
                                          ItemsSource="{Binding SelectedTextureMipOptions}"
                                          SelectedItem="{Binding SelectedTextureMipOption, Mode=TwoWay}" />
                            </Grid>
                            <ItemsControl ItemsSource="{Binding SelectedMaterial.TextureSlots}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Padding="8"
                                                CornerRadius="6"
                                                Background="{ThemeResource OmegaAssetStudio.PanelSecondaryBrush}">
                                            <Grid RowDefinitions="Auto,Auto,Auto,Auto" RowSpacing="6">
                                                <TextBlock FontWeight="SemiBold"
                                                           Text="{Binding SlotName}"
                                                           TextWrapping="Wrap" />
                                                <TextBlock Grid.Row="1"
                                                           Text="{Binding TextureName}"
                                                           TextWrapping="Wrap" />
                                                <TextBlock Grid.Row="2"
                                                           Opacity="0.8"
                                                           Text="{Binding TexturePath}"
                                                           TextWrapping="Wrap" />
                                                <Grid Grid.Row="3" ColumnDefinitions="Auto,Auto,*" RowDefinitions="Auto,Auto" ColumnSpacing="8" RowSpacing="6">
                                                    <Button Content="Select"
                                                            Click="SelectTextureSlot_Click"
                                                            Tag="{Binding}" />
                                                    <Button Grid.Column="1"
                                                            Content="Replace"
                                                            Click="ReplaceTextureSlot_Click"
                                                            Tag="{Binding}" />
                                                    <Button Grid.Column="0"
                                                            Grid.ColumnSpan="3"
                                                            Grid.Row="1"
                                                            HorizontalAlignment="Stretch"
                                                            HorizontalContentAlignment="Left"
                                                            Click="OpenTextureInTextures2_Click"
                                                            Tag="{Binding}">
                                                        <TextBlock Text="Open in Textures 2.0"
                                                                   TextWrapping="WrapWholeWords"
                                                                   TextAlignment="Left" />
                                                    </Button>
                                                </Grid>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>

                        <StackPanel Spacing="6">
                            <TextBlock FontWeight="SemiBold"
                                       Text="Scalar Parameters"
                                       TextWrapping="WrapWholeWords" />
                            <ItemsControl ItemsSource="{Binding SelectedMaterial.ScalarParameters}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Padding="8"
                                                CornerRadius="6"
                                                Background="{ThemeResource OmegaAssetStudio.PanelSecondaryBrush}">
                                            <Grid ColumnDefinitions="2*,Auto,Auto" ColumnSpacing="8">
                                                <StackPanel Grid.Column="0" Spacing="2">
                                                    <TextBlock FontWeight="SemiBold" Text="{Binding Name}" TextWrapping="Wrap" />
                                                    <TextBlock Opacity="0.8" Text="{Binding Category}" TextWrapping="Wrap" />
                                                </StackPanel>
                                                <TextBox Grid.Column="1"
                                                         MinWidth="96"
                                                         MaxWidth="160"
                                                         Text="{Binding ScalarValueText, Mode=TwoWay}"
                                                         GotFocus="ScalarTextBox_GotFocus" />
                                                <Button Grid.Column="2"
                                                        Content="Reset"
                                                        Click="ResetParameter_Click"
                                                        Tag="{Binding}" />
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>

                        <StackPanel Spacing="6">
                            <TextBlock FontWeight="SemiBold"
                                       Text="Vector Parameters"
                                       TextWrapping="WrapWholeWords" />
                            <ItemsControl ItemsSource="{Binding SelectedMaterial.VectorParameters}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Padding="8" CornerRadius="6">
                                            <Grid ColumnDefinitions="2*,Auto" ColumnSpacing="8">
                                                <StackPanel Grid.Column="0" Spacing="2">
                                                    <TextBlock FontWeight="SemiBold" Text="{Binding Name}" TextWrapping="Wrap" />
                                                    <TextBlock Opacity="0.8" Text="{Binding Category}" TextWrapping="Wrap" />
                                                </StackPanel>
                                                <Button Grid.Column="1"
                                                        Content="Reset"
                                                        Click="ResetParameter_Click"
                                                        Tag="{Binding}" />
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>
    </Grid>
</Page>

