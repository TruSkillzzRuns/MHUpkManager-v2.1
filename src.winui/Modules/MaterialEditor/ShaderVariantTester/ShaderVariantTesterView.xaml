<UserControl
    x:Class="OmegaAssetStudio.WinUI.Modules.MaterialEditor.ShaderVariantTester.ShaderVariantTesterView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:OmegaAssetStudio.WinUI.Modules.MaterialEditor.ShaderVariantTester"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                  VerticalScrollBarVisibility="Auto">
        <Grid Padding="16" RowSpacing="12">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <TextBlock Text="Shader Variant Tester" FontSize="22" FontWeight="SemiBold" />
            <StackPanel Grid.Row="0" Margin="0,32,0,0" Spacing="4">
                <TextBlock Text="{Binding SelectedShaderSummaryText}" Opacity="0.75" TextWrapping="WrapWholeWords" />
                <TextBlock Text="{Binding VariantCountText}" Opacity="0.75" TextWrapping="WrapWholeWords" />
                <TextBlock Text="{Binding SelectedPermutationSummaryText}" Opacity="0.75" TextWrapping="WrapWholeWords" />
                <TextBlock Text="{Binding ComparisonSummaryText}" Opacity="0.75" TextWrapping="WrapWholeWords" />
            </StackPanel>
            <Grid Grid.Row="1" ColumnDefinitions="*,*" ColumnSpacing="12">
                <local:ShaderVariantListControl />
                <Border Grid.Column="1"
                        Padding="12"
                        CornerRadius="12"
                        Background="{ThemeResource OmegaAssetStudio.PanelBackgroundBrush}"
                        BorderBrush="{ThemeResource OmegaAssetStudio.PanelBorderBrush}"
                        BorderThickness="1">
                    <StackPanel Spacing="8">
                        <TextBlock Text="Compare Preview" FontWeight="SemiBold" />
                        <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
                            <Border Padding="8"
                                    CornerRadius="8"
                                    Background="{ThemeResource OmegaAssetStudio.PanelSecondaryBrush}">
                                <StackPanel Spacing="4">
                                    <TextBlock Text="Baseline" FontWeight="SemiBold" />
                                    <TextBlock Text="{Binding BaselineVariantDetailText}" TextWrapping="WrapWholeWords" />
                                </StackPanel>
                            </Border>
                            <Border Grid.Column="1"
                                    Padding="8"
                                    CornerRadius="8"
                                    Background="{ThemeResource OmegaAssetStudio.PanelSecondaryBrush}">
                                <StackPanel Spacing="4">
                                    <TextBlock Text="Selected" FontWeight="SemiBold" />
                                    <TextBlock Text="{Binding SelectedVariantDetailText}" TextWrapping="WrapWholeWords" />
                                </StackPanel>
                            </Border>
                        </Grid>
                        <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
                            <Button Grid.Column="0" Click="ActivateSelectedVariant_Click">
                                <TextBlock Text="Activate Selected Variant" TextWrapping="WrapWholeWords" TextAlignment="Center" />
                            </Button>
                            <Button Grid.Column="1" Click="ExportVariantMetadata_Click">
                                <TextBlock Text="Export Variant Metadata" TextWrapping="WrapWholeWords" TextAlignment="Center" />
                            </Button>
                        </Grid>
                        <TextBlock Text="{Binding StatusText}" Opacity="0.75" TextWrapping="WrapWholeWords" />
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>
    </ScrollViewer>
</UserControl>
